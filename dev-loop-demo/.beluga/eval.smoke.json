{
  "name": "dev-loop-demo-smoke",
  "samples": [
    {
      "Input": "Please echo: hello",
      "ExpectedOutput": "hello",
      "Turns": [
        {
          "Role": "assistant",
          "ToolCalls": [
            {"ID": "call_1", "Name": "echo", "Arguments": "{\"message\":\"hello\"}"}
          ]
        },
        {"Role": "tool", "Content": "hello"},
        {"Role": "assistant", "Content": "hello"}
      ],
      "ExpectedTools": ["echo"]
    },
    {
      "Input": "Please echo: world",
