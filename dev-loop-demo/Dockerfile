# syntax=docker/dockerfile:1.7
# Multi-stage Dockerfile for dev-loop-demo.
# Generated by `beluga init` on 2026-04-22T01:32:33Z.

FROM golang:1.25-alpine AS builder
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/dev-loop-demo .

# NOTE: this image requires CGO_ENABLED=0. If you add a package with CGo
# requirements, switch to gcr.io/distroless/base-debian12 or a glibc-based
# runtime image.
FROM gcr.io/distroless/static-debian12:nonroot

LABEL org.opencontainers.image.source="https://example.com/dev-loop-demo"
LABEL org.opencontainers.image.version="v2.13.0"
LABEL org.opencontainers.image.title="dev-loop-demo"

USER nonroot:nonroot
COPY --from=builder /out/dev-loop-demo /dev-loop-demo
ENTRYPOINT ["/dev-loop-demo"]
