# Copy this file to `.env` and fill in real values.
# Never commit `.env` — see .gitignore.

OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
# BELUGA_MODEL=gpt-4o-mini

# Pretty-print OTel spans to stdout on first run so you can see the agent's
# trace end-to-end. Unset (or set OTEL_EXPORTER_OTLP_ENDPOINT instead) when
# you wire a collector. OTEL_SDK_DISABLED=true short-circuits all tracing.
BELUGA_OTEL_STDOUT=1
